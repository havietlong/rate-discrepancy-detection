{
  "patterns": {
    "date_specific": [
      "RATE\\s*AMOUNT\\w*\\s*->([\\d.,]+).*?from\\s*(\\d{2}-[A-Z]{3}-\\d{2})\\s*to\\s*(\\d{2}-[A-Z]{3}-\\d{2})",
      "SHAREAMOUNT\\w*\\s*->([\\d.,]+).*?from\\s*(\\d{2}-[A-Z]{3}-\\d{2})\\s*to\\s*(\\d{2}-[A-Z]{3}-\\d{2})"
    ],
    "nett_rates": [
      "VND?\\s*([\\d.,]+)\\s*net{1,2}\\s*",
      "VND?\\s*([\\d.,]+)net{1,2}",
      "VND?\\s*([\\d.,]+)\\s*net{1,2}(?:\\s|$|\\n)",
      "([\\d.,]+)\\s*net{1,2}",
      "([\\d.,]+)\\s*NETT",
      "Total\\s+RC.*?([\\d.,]+)\\s*net",
      "Total\\s+([\\d.,]+)\\s*VND\\s*net",
      "TOTAL\\s+([\\d.,]+)\\s*NETT\\s*/?\\s*MONTH"
    ],
    "pp_rates": [
      "VND?\\s*([\\d.,]+)\\s*\\+\\+",
      "VND?\\s*([\\d.,]+)\\s*\\+\\+\\s*$",
      "([\\d.,]+)\\s*\\+\\+",
      "VND?\\s*([\\d.,]+)\\s*\\+\\+\\s*(?:rate)?",
      "VND?\\s*([\\d.,]+)\\s*\\+\\+\\s*KGB",
      "VND?\\s*([\\d.,]+)\\s*\\+\\+\\s*SGL"
    ],
    "flat_rates": [
      "RATE\\s*AMOUNT\\w*\\s*->([\\d.,]+)(?:\\s|\\.|$)",
      "SHAREAMOUNT\\w*\\s*->([\\d.,]+)(?:\\s|\\.|$)",
      "Rate\\s*:\\s*VND?\\s*([\\d.,]+)"
    ],
    "monthly": [
      "([\\d.,]+)\\s*(?:net)?/?\\s*(?:per\\s+)?month",
      "([\\d.,]+)\\s*VND\\s*/\\s*month",
      "([\\d.,]+)\\s*NETT\\s*/\\s*MONTH",
      "TOTAL\\s+([\\d.,]+)\\s*NETT\\s*/\\s*MONTH",
      "([\\d.,]+)\\s*NETT\\s*MONTH",
      "([\\d.,]+)\\s*net\\s*month",
      "monthly\\s*rate\\s*:?\\s*([\\d.,]+)",
      "/month"
    ],
    "rate_adjustments": [
      "as balance",
      "balance the room charge",
      "adjusted rate",
      "remaining balance",
      "adjustment",
      "prorated",
      "pro-rated",
      "credit",
      "refund"
    ]
  },
  "skip_keywords": [
    "deposit",
    "deposited",
    "prepaid",
    "paid",
    "VAT",
    "discount",
    "complimentary",
    "free",
    "laundry",
    "buffet"
  ],
  "rate_cleaning": {
    "remove_commas": true,
    "remove_dots": true,
    "fix_missing_zeros": true,
    "minimum_rate": 100000,
    "maximum_rate": 100000000
  }
}